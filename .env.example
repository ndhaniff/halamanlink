# App
APP_DOMAIN=localhost
APP_URL=http://localhost:4321
SESSION_SECRET=change-me-to-a-long-random-string

# Traefik subdomain regex (Coolify only — bracket-escape dots in APP_DOMAIN)
# links.halaman.cc -> links[.]halaman[.]cc
TRAEFIK_DOMAIN_LABEL=links[.]halaman[.]cc

# Stripe (optional for local dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# Production SQLite file path (required for astro build in Docker)
ASTRO_DATABASE_FILE=./data/content.db

# Uploaded avatars (optional — defaults to ./data/uploads)
# UPLOAD_DIR=/app/data/uploads
