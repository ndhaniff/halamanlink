---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <div class="flex min-h-screen flex-col items-center justify-center px-4 text-center">
    <h1 class="hl-display text-5xl">404</h1>
    <p class="mt-3 text-sm" style="color: var(--hl-ink-2);">This page doesn't exist or isn't published.</p>
    <a href="/" class="hl-btn hl-btn-primary mt-6 px-4 py-2 text-sm">Go home</a>
  </div>
</BaseLayout>
