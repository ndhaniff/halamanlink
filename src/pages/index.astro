---
import BaseLayout from "../layouts/BaseLayout.astro";
import Wordmark from "../components/Wordmark.astro";
---

<BaseLayout title="Halamanlink — Your link-in-bio page">
  <div class="hl-grain relative min-h-screen overflow-hidden" style="background: var(--hl-bg);">
    <header class="relative z-[2] flex items-center justify-between px-5 py-6 md:px-14">
      <Wordmark size={16} />
      <nav class="hidden gap-8 text-sm md:flex" style="color: var(--hl-ink-2);">
        <a class="hl-link-quiet" href="#features">Features</a>
        <a class="hl-link-quiet" href="#pricing">Pricing</a>
      </nav>
      <div class="flex items-center gap-2.5">
        <a href="/login" class="hidden text-sm md:inline" style="color: var(--hl-ink-2);">Log in</a>
        <a href="/signup" class="hl-btn hl-btn-primary px-4 py-2 text-[13px]">Claim your link</a>
      </div>
    </header>

    <section class="relative px-5 pb-14 pt-10 md:px-20 md:pb-20 md:pt-16">
      <div
        aria-hidden="true"
        class="absolute rounded-full blur-[70px]"
        style="top: 40px; right: -100px; width: 480px; height: 480px; background: var(--hl-sage); opacity: 0.18;"
      ></div>
      <div
        aria-hidden="true"
        class="absolute rounded-full blur-[70px]"
        style="bottom: -80px; left: -60px; width: 380px; height: 380px; background: var(--hl-clay); opacity: 0.16;"
      ></div>

      <div class="relative mx-auto max-w-[1080px]">
        <span class="hl-chip hl-chip-sage mb-5">
          <span class="hl-dot"></span>
          new — themed appearance editor
        </span>
        <h1
          class="hl-display m-0 max-w-[940px] text-[56px] leading-[0.96] tracking-tight md:text-[112px]"
          style="color: var(--hl-ink);"
        >
          One quiet page<br />
          for everywhere<br />
          <em class="hl-italic" style="color: var(--hl-sage-deep);">you are.</em>
        </h1>
        <p class="mt-7 max-w-[520px] text-base leading-relaxed md:text-[19px]" style="color: var(--hl-ink-2);">
          Halamanlink is a calm link-in-bio for makers, writers and small studios. Bring your audience to a page that finally looks like you — on your own subdomain, with analytics that respect them.
        </p>
        <div class="mt-8 flex flex-wrap gap-2.5">
          <a href="/signup" class="hl-btn hl-btn-primary px-5 py-3 text-sm">Start free</a>
          <a href="/p/demo" class="hl-btn hl-btn-ghost px-5 py-3 text-sm">See a live page</a>
        </div>
        <div class="mt-5 flex flex-wrap items-center gap-4 text-[12.5px]" style="color: var(--hl-ink-3);">
          <span>✓ 7 links free, forever</span>
          <span>✓ No credit card</span>
          <span class="hidden md:inline">✓ Your subdomain in 30s</span>
        </div>
      </div>
    </section>

    <section id="features" class="relative px-5 pb-14 md:px-20 md:pb-24">
      <div class="mx-auto grid max-w-[1080px] gap-4 md:grid-cols-3">
        {
          [
            {
              eyebrow: "01 — Themes",
              title: "Five quiet presets.",
              body: "Linen, Sage, Dusk, Clay, Noir. Tune type, radius and accent without touching CSS.",
            },
            {
              eyebrow: "02 — Analytics",
              title: "Clicks that don't creep.",
              body: "Hashed IPs, no third-party trackers. See the link that's working today, not last quarter.",
            },
            {
              eyebrow: "03 — Domains",
              title: "Your subdomain ships first.",
              body: "you.halamanlink.app instantly. Bring your own domain when you upgrade to Pro.",
            },
          ].map((f) => (
            <div class="hl-card hl-grain relative p-6">
              <div class="hl-eyebrow">{f.eyebrow}</div>
              <h3 class="hl-display mb-2 mt-2.5 text-[28px] leading-tight">{f.title}</h3>
              <p class="m-0 text-[13.5px] leading-relaxed" style="color: var(--hl-ink-2);">{f.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section id="pricing" class="hidden px-20 pb-20 md:block">
      <div
        class="hl-card mx-auto grid max-w-[1080px] gap-10 p-10 md:grid-cols-[1.2fr_1fr_1fr]"
        style="background: var(--hl-sage-soft); border-color: oklch(0.67 0.068 145 / 0.25);"
      >
        <div>
          <div class="hl-eyebrow" style="color: var(--hl-sage-deep);">Pricing</div>
          <h3 class="hl-display mb-1.5 mt-2.5 text-4xl">Free, until you outgrow it.</h3>
          <p class="m-0 text-[13.5px]" style="color: var(--hl-ink-2);">
            Upgrade when you need a custom domain or more than seven links. No surprises.
          </p>
        </div>
        <div>
          <div class="hl-eyebrow">Free</div>
          <div class="hl-display my-1.5 text-[44px]">$0</div>
          <ul class="m-0 list-none p-0 text-[13px] leading-[1.9]" style="color: var(--hl-ink-2);">
            <li>7 links</li>
            <li>5 themes</li>
            <li>7-day analytics</li>
          </ul>
        </div>
        <div>
          <div class="hl-eyebrow" style="color: var(--hl-clay-deep);">Pro</div>
          <div class="hl-display my-1.5 text-[44px]">
            $6<span class="text-lg" style="color: var(--hl-ink-3);"> /mo</span>
          </div>
          <ul class="m-0 list-none p-0 text-[13px] leading-[1.9]" style="color: var(--hl-ink-2);">
            <li>Unlimited links · all themes</li>
            <li>Custom domain</li>
            <li>Full analytics history</li>
          </ul>
        </div>
      </div>
    </section>

    <footer
      class="flex items-center justify-between border-t px-5 py-8 text-xs md:px-20"
      style="color: var(--hl-ink-3); border-color: var(--hl-line);"
    >
      <Wordmark size={12} color="var(--hl-ink-3)" />
      <span>© 2026 · made slowly</span>
    </footer>
  </div>
</BaseLayout>
