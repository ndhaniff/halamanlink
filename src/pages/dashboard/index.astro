---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import DashHeader from "../../components/dashboard/DashHeader.astro";
import LinkEditor from "../../components/dashboard/LinkEditor.astro";
import SocialEditor from "../../components/dashboard/SocialEditor.astro";
import ProfileAvatar from "../../components/ProfileAvatar.astro";
import {
  getLinksByProfileId,
  getProfileByUserId,
  getUserPlan,
} from "../../lib/db-queries";
import { PLAN_LIMITS } from "../../lib/plans";

export const prerender = false;

const user = Astro.locals.user!;
const profile = await getProfileByUserId(user.id);
if (!profile) return Astro.redirect("/signup");

const links = await getLinksByProfileId(profile.id, "link");
const socialLinks = await getLinksByProfileId(profile.id, "social");
const plan = await getUserPlan(user.id);
const activeCount = links.filter((l) => l.isActive).length;
---

<DashboardLayout title="Links" active="links">
  <DashHeader
    title="Your links"
    subtitle={`${links.length} links · ${activeCount} active · ${socialLinks.length} social icons`}
  >
    <a slot="actions" href="/dashboard/appearance" class="hl-btn hl-btn-soft px-3.5 py-2 text-[13px]">
      Edit profile
    </a>
  </DashHeader>

  <div class="hl-card mx-7 mt-7 flex items-center gap-4 p-5">
    <ProfileAvatar
      avatarUrl={profile.avatarUrl}
      displayName={profile.displayName}
      size={64}
      textSize="text-[26px]"
    />
    <div class="min-w-0 flex-1">
      <div class="hl-eyebrow">Header block</div>
      <div class="hl-display text-[22px]">{profile.displayName}</div>
      <div class="truncate text-[12.5px]" style="color: var(--hl-ink-2);">{profile.bio || "Add a bio in Appearance"}</div>
    </div>
  </div>

  <LinkEditor initialLinks={links} plan={plan} maxLinks={PLAN_LIMITS.free.maxLinks} />

  <div class="hl-card mx-7 mb-7 overflow-hidden">
    <SocialEditor
      initialLinks={socialLinks}
      plan={plan}
      maxSocialLinks={PLAN_LIMITS.free.maxSocialLinks}
    />
  </div>
</DashboardLayout>
