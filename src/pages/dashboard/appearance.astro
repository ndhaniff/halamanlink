---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import AvatarEditorHost from "../../components/dashboard/AvatarEditorHost.astro";
import DashHeader from "../../components/dashboard/DashHeader.astro";
import ProfileAvatar from "../../components/ProfileAvatar.astro";
import { MAX_AVATAR_BYTES, getAvatarSourceUrl } from "../../lib/uploads";
import {
  getProfileByUserId,
  getUserPlan,
} from "../../lib/db-queries";
import { getAvailableThemes, parseTheme } from "../../lib/themes";

export const prerender = false;

const user = Astro.locals.user!;
const profile = await getProfileByUserId(user.id);
if (!profile) return Astro.redirect("/signup");

const plan = await getUserPlan(user.id);
const themes = getAvailableThemes(plan);
const currentTheme = parseTheme(profile.theme);
const previewUrl = `/p/${profile.slug}`;
const avatarPreview = profile.avatarUrl || "";
const avatarSourceUrl = await getAvatarSourceUrl(profile.id);
const avatarEditUrl = avatarSourceUrl || avatarPreview;
const avatarHasSource = Boolean(avatarSourceUrl);
---

<DashboardLayout title="Appearance" active="appearance" showPreview={false}>
  <DashHeader
    title="Appearance"
    subtitle="Choose a theme, then fine-tune the details. Changes preview live."
  />
  <div class="grid md:grid-cols-[1fr_380px]" style="height: calc(100vh - 86px);">
    <div class="overflow-auto p-7">
      <div class="mb-7">
        <div class="hl-eyebrow">01 — Theme</div>
        <div class="mt-4 grid grid-cols-2 gap-3 lg:grid-cols-3">
          {
            themes.map((theme) => (
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="theme"
                  value={theme.id}
                  checked={currentTheme.id === theme.id}
                  class="peer sr-only"
                />
                <div
                  class="overflow-hidden rounded-xl border-2 border-transparent p-0 peer-checked:border-[var(--hl-sage-deep)]"
                  style="outline-offset: 4px;"
                >
                  <div
                    class="flex h-[132px] flex-col justify-between p-4"
                    style={{
                      background: theme.bg,
                      border: `1px solid ${theme.btnBorder}`,
                      borderRadius: "12px",
                    }}
                  >
                    <div class="flex gap-1">
                      {theme.swatch.map((s) => (
                        <span
                          class="h-4 w-4 rounded-full border border-black/5"
                          style={{ background: s }}
                        ></span>
                      ))}
                    </div>
                    <div
                      class="px-2.5 py-1.5 text-[11px]"
                      style={{
                        background: theme.btnBg,
                        color: theme.btnFg,
                        border: `1px solid ${theme.btnBorder}`,
                        borderRadius: `${Math.min(theme.radius, 10)}px`,
                        fontFamily: theme.font,
                      }}
                    >
                      Sample link
                    </div>
                  </div>
                  <div class="mt-2.5 flex items-center justify-between text-[13px] font-medium">
                    {theme.name}
                    {currentTheme.id === theme.id && <span style="color: var(--hl-sage-deep);">✓</span>}
                  </div>
                </div>
              </label>
            ))
          }
        </div>
      </div>

      <form id="appearance-form" class="hl-card space-y-4 p-5">
        <div>
          <label class="hl-label">Avatar</label>
          <div class="flex flex-wrap items-center gap-4">
            {
              avatarPreview ? (
                <button
                  type="button"
                  id="avatar-preview-button"
                  class="group relative rounded-full"
                  title="Adjust photo position"
                >
                  <ProfileAvatar
                    avatarUrl={avatarPreview}
                    displayName={profile.displayName}
                    size={80}
                    textSize="text-2xl"
                    class="transition group-hover:brightness-95"
                    imgClass="shadow-[var(--hl-shadow-1)]"
                  />
                  <span
                    class="pointer-events-none absolute inset-0 grid place-items-center rounded-full text-[11px] font-medium text-white opacity-0 transition group-hover:opacity-100"
                    style="background: rgb(20 18 16 / 0.45);"
                  >
                    Edit
                  </span>
                </button>
              ) : (
                <ProfileAvatar
                  avatarUrl=""
                  displayName={profile.displayName}
                  size={80}
                  textSize="text-2xl"
                  imgClass="shadow-[var(--hl-shadow-1)]"
                />
              )
            }
            <div class="flex flex-col gap-2">
              <label class="hl-btn hl-btn-soft w-fit cursor-pointer px-3 py-2 text-[13px]">
                Upload photo
                <input id="avatar-file" type="file" accept="image/jpeg,image/png,image/webp,image/gif" class="sr-only" />
              </label>
              {
                avatarPreview && (
                  <>
                    <button type="button" id="avatar-adjust" class="hl-btn hl-btn-soft w-fit px-3 py-2 text-[13px]">
                      Adjust position
                    </button>
                    <button type="button" id="avatar-remove" class="hl-btn hl-btn-ghost w-fit px-3 py-2 text-[13px]">
                      Remove photo
                    </button>
                  </>
                )
              }
              <p class="text-[11.5px]" style="color: var(--hl-ink-3);">JPG, PNG, WebP or GIF · max 2 MB · drag the circle to crop</p>
            </div>
          </div>
          <p id="avatar-status" class="mt-2 hidden text-sm" style="color: var(--hl-sage-deep);"></p>
        </div>
        <div>
          <label class="hl-label" for="displayName">Display name</label>
          <input id="displayName" value={profile.displayName} class="hl-input" />
        </div>
        <div>
          <label class="hl-label" for="bio">Bio</label>
          <textarea id="bio" rows="3" class="hl-input">{profile.bio}</textarea>
        </div>
        <div>
          <div class="hl-eyebrow mb-2">Pinned location</div>
          <p class="mb-3 text-[12px] leading-relaxed" style="color: var(--hl-ink-3);">
            Optional Google Map on your page. Paste coordinates from Google Maps (right-click a place → coordinates). The site admin must set <code class="hl-mono text-[11px]">GOOGLE_MAPS_API_KEY</code> for the embedded map.
          </p>
          <div class="grid gap-3 sm:grid-cols-2">
            <div>
              <label class="hl-label" for="locationLat">Latitude</label>
              <input
                id="locationLat"
                type="text"
                inputmode="decimal"
                placeholder="2.189594"
                value={profile.locationLat ?? ""}
                class="hl-input"
              />
            </div>
            <div>
              <label class="hl-label" for="locationLng">Longitude</label>
              <input
                id="locationLng"
                type="text"
                inputmode="decimal"
                placeholder="102.250087"
                value={profile.locationLng ?? ""}
                class="hl-input"
              />
            </div>
          </div>
          <div class="mt-3">
            <label class="hl-label" for="locationLabel">Location label (optional)</label>
            <input
              id="locationLabel"
              type="text"
              placeholder="Our office"
              value={profile.locationLabel ?? ""}
              class="hl-input"
            />
          </div>
        </div>
        <div>
          <label class="hl-label" for="avatarUrl">Or paste image URL</label>
          <input id="avatarUrl" value={profile.avatarUrl.split("?")[0]} placeholder="https://..." class="hl-input" />
        </div>
        <label class="flex items-center gap-2 text-sm">
          <input id="isPublished" type="checkbox" checked={profile.isPublished} />
          Page is published
        </label>
        <p id="error" class="hidden text-sm" style="color: #b91c1c;"></p>
        <p id="success" class="hidden text-sm" style="color: var(--hl-sage-deep);">Saved!</p>
        <button type="submit" class="hl-btn hl-btn-primary px-4 py-2 text-sm">Publish changes</button>
      </form>
    </div>

    <aside class="hidden border-l p-5 md:flex md:flex-col" style="border-color: var(--hl-line); background: var(--hl-bg);">
      <div class="hl-eyebrow mb-3 flex justify-between">
        <span>Preview</span>
        <span class="hl-mono" style="color: var(--hl-ink-3);">{currentTheme.name}</span>
      </div>
      <div class="hl-phone-frame flex-1">
        <div class="hl-phone-screen">
          <iframe src={previewUrl} title="Preview" class="h-full w-full border-0"></iframe>
        </div>
      </div>
    </aside>
  </div>

  <AvatarEditorHost />
</DashboardLayout>

<script define:vars={{ themes, avatarPreview, avatarEditUrl, avatarHasSource, maxAvatarBytes: MAX_AVATAR_BYTES }}>
  const form = document.getElementById("appearance-form");
  const errorEl = document.getElementById("error");
  const successEl = document.getElementById("success");
  const avatarFile = document.getElementById("avatar-file");
  const avatarAdjust = document.getElementById("avatar-adjust");
  const avatarPreviewButton = document.getElementById("avatar-preview-button");
  const avatarRemove = document.getElementById("avatar-remove");
  const avatarStatus = document.getElementById("avatar-status");
  let pendingSourceFile = null;

  async function uploadAvatarBlob(blob) {
    errorEl?.classList.add("hidden");
    avatarStatus?.classList.remove("hidden");
    if (avatarStatus) avatarStatus.textContent = "Uploading…";

    try {
      const body = new FormData();
      body.append("avatar", blob, "avatar.jpg");
      if (pendingSourceFile) {
        body.append("source", pendingSourceFile);
      }

      const res = await fetch("/api/avatar", { method: "POST", body });
      const json = await res.json().catch(() => ({}));

      if (!res.ok) {
        if (errorEl) {
          errorEl.textContent = json.error || "Upload failed";
          errorEl.classList.remove("hidden");
        }
        if (avatarStatus) avatarStatus.textContent = "";
        avatarStatus?.classList.add("hidden");
        return;
      }

      window.location.reload();
    } catch {
      if (errorEl) {
        errorEl.textContent = "Upload failed. Check your connection and try again.";
        errorEl.classList.remove("hidden");
      }
      if (avatarStatus) avatarStatus.textContent = "";
      avatarStatus?.classList.add("hidden");
    }
  }

  function runAvatarEditor(options) {
    if (typeof window.openAvatarCropEditor !== "function") {
      if (errorEl) {
        errorEl.textContent = "Photo editor is still loading. Try again.";
        errorEl.classList.remove("hidden");
      }
      return;
    }

    window.openAvatarCropEditor({
      ...options,
      onConfirm: uploadAvatarBlob,
      onCancel: () => {
        avatarFile.value = "";
        pendingSourceFile = null;
      },
      onLoadError: () => {
        if (errorEl) {
          errorEl.textContent =
            "Could not load this image for editing. Upload the photo again to enable repositioning.";
          errorEl.classList.remove("hidden");
        }
        avatarFile.value = "";
        pendingSourceFile = null;
      },
    });
  }

  async function openAvatarEditor(source) {
    errorEl?.classList.add("hidden");

    if (source.file) {
      runAvatarEditor({ file: source.file, hasSource: true });
      return;
    }

    let editUrl = avatarEditUrl || avatarPreview;
    let hasSource = avatarHasSource;

    try {
      const res = await fetch("/api/avatar");
      if (res.ok) {
        const data = await res.json();
        editUrl = data.editUrl || avatarPreview;
        hasSource = Boolean(data.hasSource);
      }
    } catch {
      // fall back to server-rendered values
    }

    if (!editUrl) {
      if (errorEl) {
        errorEl.textContent = "Upload a photo first.";
        errorEl.classList.remove("hidden");
      }
      return;
    }

    runAvatarEditor({ url: editUrl, hasSource });
  }

  avatarFile?.addEventListener("change", () => {
    const file = avatarFile.files?.[0];
    if (!file) return;

    errorEl?.classList.add("hidden");

    if (file.size > maxAvatarBytes) {
      if (errorEl) {
        errorEl.textContent = "Image must be 2 MB or smaller.";
        errorEl.classList.remove("hidden");
      }
      avatarFile.value = "";
      return;
    }

    pendingSourceFile = file;
    openAvatarEditor({ file });
  });

  avatarAdjust?.addEventListener("click", async () => {
    if (!avatarPreview) return;
    await openAvatarEditor({});
  });

  avatarPreviewButton?.addEventListener("click", async () => {
    await openAvatarEditor({});
  });

  avatarRemove?.addEventListener("click", async () => {
    errorEl?.classList.add("hidden");
    const res = await fetch("/api/avatar", { method: "DELETE" });
    const json = await res.json();
    if (!res.ok) {
      if (errorEl) {
        errorEl.textContent = json.error || "Remove failed";
        errorEl.classList.remove("hidden");
      }
      return;
    }
    window.location.reload();
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl?.classList.add("hidden");
    successEl?.classList.add("hidden");

    const themeId = document.querySelector('input[name="theme"]:checked')?.value;
    const selectedTheme = themes.find((t) => t.id === themeId);

    const res = await fetch("/api/profile", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        displayName: document.getElementById("displayName")?.value,
        bio: document.getElementById("bio")?.value,
        locationLat: document.getElementById("locationLat")?.value,
        locationLng: document.getElementById("locationLng")?.value,
        locationLabel: document.getElementById("locationLabel")?.value,
        avatarUrl: document.getElementById("avatarUrl")?.value,
        isPublished: document.getElementById("isPublished")?.checked,
        theme: selectedTheme,
      }),
    });

    const json = await res.json();
    if (!res.ok) {
      if (errorEl) {
        errorEl.textContent = json.error || "Save failed";
        errorEl.classList.remove("hidden");
      }
      return;
    }

    successEl?.classList.remove("hidden");
    document.querySelector("iframe")?.contentWindow?.location.reload();
  });
</script>
