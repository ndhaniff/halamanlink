<div
  id="avatar-crop-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  style="background: rgb(20 18 16 / 0.55);"
  aria-hidden="true"
  role="presentation"
>
  <div
    class="hl-card w-full max-w-[360px] p-5 shadow-xl"
    role="dialog"
    aria-modal="true"
    aria-labelledby="avatar-crop-title"
  >
    <div class="mb-4 flex items-start justify-between gap-3">
      <div>
        <div id="avatar-crop-title" class="hl-display text-[20px]">Adjust photo</div>
        <p class="mt-1 text-[12.5px]" style="color: var(--hl-ink-2);">
          Drag the circle to choose the crop. Use the slider to zoom the photo.
        </p>
      </div>
      <button type="button" id="avatar-crop-close" class="hl-btn hl-btn-ghost px-2 py-1 text-lg leading-none">
        ×
      </button>
    </div>

    <div
      id="avatar-crop-stage"
      class="relative mx-auto cursor-grab overflow-hidden rounded-[var(--hl-radius)] active:cursor-grabbing"
      style="width: 280px; height: 280px; background: var(--hl-bg-2); touch-action: none;"
    >
      <img
        id="avatar-crop-image"
        alt=""
        draggable="false"
        class="pointer-events-none absolute left-1/2 top-1/2 max-w-none select-none"
        style="transform: translate(-50%, -50%);"
      />
      <div
        id="avatar-crop-circle"
        aria-hidden="true"
        class="pointer-events-none absolute rounded-full ring-2 ring-white"
        style="box-shadow: 0 0 0 9999px rgb(20 18 16 / 0.55);"
      ></div>
    </div>

    <div class="mt-5">
      <label class="hl-label" for="avatar-crop-zoom">Zoom</label>
      <input id="avatar-crop-zoom" type="range" min="1" max="3" step="0.01" value="1" class="mt-2 w-full accent-[var(--hl-sage-deep)]" />
    </div>

    <p id="avatar-crop-error" class="mt-3 hidden text-sm" style="color: #b91c1c;"></p>

    <div class="mt-5 flex justify-end gap-2">
      <button type="button" id="avatar-crop-cancel" class="hl-btn hl-btn-soft px-4 py-2 text-[13px]">
        Cancel
      </button>
      <button type="button" id="avatar-crop-save" class="hl-btn hl-btn-primary px-4 py-2 text-[13px]">
        Save photo
      </button>
    </div>
  </div>
</div>

<script>
  import {
    AVATAR_CROP_CIRCLE,
    AVATAR_CROP_STAGE,
    clampCircle,
    cropAvatarToBlob,
    getCoverScale,
    loadImageSource,
  } from "../../lib/avatar-crop";

  const modal = document.getElementById("avatar-crop-modal");
  const stage = document.getElementById("avatar-crop-stage");
  const imageEl = document.getElementById("avatar-crop-image");
  const circleEl = document.getElementById("avatar-crop-circle");
  const zoomEl = document.getElementById("avatar-crop-zoom");
  const errorEl = document.getElementById("avatar-crop-error");
  const saveBtn = document.getElementById("avatar-crop-save");
  const cancelBtn = document.getElementById("avatar-crop-cancel");
  const closeBtn = document.getElementById("avatar-crop-close");

  if (
    !(modal instanceof HTMLElement) ||
    !(stage instanceof HTMLElement) ||
    !(imageEl instanceof HTMLImageElement) ||
    !(circleEl instanceof HTMLElement) ||
    !(zoomEl instanceof HTMLInputElement) ||
    !(errorEl instanceof HTMLElement) ||
    !(saveBtn instanceof HTMLButtonElement)
  ) {
    throw new Error("Avatar crop editor failed to initialize");
  }

  let activeImage = null;
  let cleanupPreviewUrl = null;
  let circleX = 0;
  let circleY = 0;
  let userScale = 1;
  let dragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let dragOriginX = 0;
  let dragOriginY = 0;
  let onConfirm = null;
  let onCancel = null;

  function showError(message) {
    errorEl.textContent = message;
    errorEl.classList.remove("hidden");
  }

  function hideError() {
    errorEl.textContent = "";
    errorEl.classList.add("hidden");
  }

  function applyLayout() {
    if (!activeImage) return;

    const scale =
      getCoverScale(activeImage.naturalWidth, activeImage.naturalHeight, AVATAR_CROP_CIRCLE) * userScale;

    imageEl.style.width = `${activeImage.naturalWidth * scale}px`;
    imageEl.style.height = `${activeImage.naturalHeight * scale}px`;

    circleEl.style.width = `${AVATAR_CROP_CIRCLE}px`;
    circleEl.style.height = `${AVATAR_CROP_CIRCLE}px`;
    circleEl.style.left = `calc(50% + ${circleX}px - ${AVATAR_CROP_CIRCLE / 2}px)`;
    circleEl.style.top = `calc(50% + ${circleY}px - ${AVATAR_CROP_CIRCLE / 2}px)`;
  }

  function syncCircle() {
    if (!activeImage) return;

    const clamped = clampCircle(
      circleX,
      circleY,
      activeImage.naturalWidth,
      activeImage.naturalHeight,
      AVATAR_CROP_STAGE,
      AVATAR_CROP_CIRCLE,
      userScale,
    );
    circleX = clamped.x;
    circleY = clamped.y;
    applyLayout();
  }

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    modal.setAttribute("aria-hidden", "true");
    cleanupPreviewUrl?.();
    cleanupPreviewUrl = null;
    activeImage = null;
    imageEl.removeAttribute("src");
    dragging = false;
    hideError();
    onCancel?.();
    onConfirm = null;
    onCancel = null;
  }

  function openModal() {
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    modal.setAttribute("aria-hidden", "false");
  }

  async function openAvatarCropEditor(options) {
    hideError();
    circleX = 0;
    circleY = 0;
    userScale = 1;
    zoomEl.value = "1";
    onConfirm = options.onConfirm ?? null;
    onCancel = options.onCancel ?? null;

    try {
      const source = options.file ?? options.url;
      if (!source) throw new Error("No image provided");

      const loaded = await loadImageSource(source);
      activeImage = loaded.image;
      cleanupPreviewUrl = loaded.cleanup;
      imageEl.src = loaded.previewUrl;

      const isSquareCrop =
        activeImage.naturalWidth === activeImage.naturalHeight &&
        activeImage.naturalWidth <= AVATAR_CROP_OUTPUT;
      if (isSquareCrop && !options.hasSource && !options.file) {
        userScale = 1.5;
        zoomEl.value = "1.5";
      }

      syncCircle();
      openModal();
    } catch {
      options.onLoadError?.();
      options.onCancel?.();
    }
  }

  zoomEl.addEventListener("input", () => {
    userScale = Number(zoomEl.value) || 1;
    syncCircle();
  });

  stage.addEventListener("pointerdown", (event) => {
    if (!activeImage) return;
    dragging = true;
    dragStartX = event.clientX;
    dragStartY = event.clientY;
    dragOriginX = circleX;
    dragOriginY = circleY;
    stage.setPointerCapture(event.pointerId);
  });

  stage.addEventListener("pointermove", (event) => {
    if (!dragging) return;
    circleX = dragOriginX + (event.clientX - dragStartX);
    circleY = dragOriginY + (event.clientY - dragStartY);
    syncCircle();
  });

  function stopDragging(event) {
    if (!dragging) return;
    dragging = false;
    if (stage.hasPointerCapture(event.pointerId)) {
      stage.releasePointerCapture(event.pointerId);
    }
  }

  stage.addEventListener("pointerup", stopDragging);
  stage.addEventListener("pointercancel", stopDragging);

  stage.addEventListener(
    "wheel",
    (event) => {
      if (!activeImage) return;
      event.preventDefault();
      userScale = Math.min(3, Math.max(1, userScale + (event.deltaY < 0 ? 0.05 : -0.05)));
      zoomEl.value = String(userScale);
      syncCircle();
    },
    { passive: false },
  );

  async function handleSave() {
    if (!activeImage || !onConfirm) return;

    hideError();
    saveBtn.disabled = true;
    saveBtn.textContent = "Saving…";

    try {
      const blob = await cropAvatarToBlob(activeImage, {
        circleX,
        circleY,
        userScale,
      });
      await onConfirm(blob);
      closeModal();
    } catch {
      showError("Could not save this image. If it is an external URL, upload the file instead.");
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = "Save photo";
    }
  }

  saveBtn.addEventListener("click", handleSave);
  cancelBtn?.addEventListener("click", closeModal);
  closeBtn?.addEventListener("click", closeModal);

  modal.addEventListener("click", (event) => {
    if (event.target === modal) closeModal();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modal.classList.contains("hidden")) {
      closeModal();
    }
  });

  window.openAvatarCropEditor = openAvatarCropEditor;
</script>
