---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="hl-dash-header">
  <div>
    <h1 class="hl-display m-0 text-[34px] tracking-tight">{title}</h1>
    {subtitle && <p class="m-0 mt-1 text-[13.5px]" style="color: var(--hl-ink-2)">{subtitle}</p>}
  </div>
  <div class="flex gap-2">
    <slot name="actions" />
  </div>
</div>
