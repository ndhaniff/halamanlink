---
import IconPicker from "./IconPicker.astro";
import { getUrlIconRulesForClient } from "../../lib/link-icons";

interface Props {
  initialLinks: Array<{
    id: string;
    title: string;
    url: string;
    icon: string;
    isActive: boolean;
    openInNewTab: boolean;
    sortOrder: number;
  }>;
  plan: "free" | "pro";
  maxSocialLinks: number;
}

const { initialLinks, plan, maxSocialLinks } = Astro.props;
const urlIconRules = getUrlIconRulesForClient();
---

<div class="border-t px-4 pb-7 pt-6 md:px-7" style="border-color: var(--hl-line);">
  <div class="mb-4">
    <div class="hl-eyebrow">Social icons</div>
    <p class="mt-1 text-[13px]" style="color: var(--hl-ink-2);">
      Icon-only links shown in a row below your bio on your public page.
    </p>
  </div>

  <form id="add-social-form" class="mb-5 flex flex-wrap items-end gap-2">
    <div class="min-w-[200px] flex-[2]">
      <label class="hl-label" for="new-social-url">URL</label>
      <input id="new-social-url" placeholder="https://instagram.com/you" required class="hl-input mt-1" />
    </div>
    <div>
      <label class="hl-label">Icon</label>
      <div class="mt-1">
        <IconPicker id="new-social-icon" value="instagram" socialOnly />
      </div>
    </div>
    <button type="submit" class="hl-btn hl-btn-primary px-4 py-2.5 text-[13px]">Add icon</button>
    <label class="flex items-center gap-1.5 self-end pb-2.5 text-xs" style="color: var(--hl-ink-2);">
      <input id="new-social-open-tab" type="checkbox" checked />
      New tab
    </label>
  </form>

  <p id="social-error" class="mb-4 hidden text-sm" style="color: #b91c1c;"></p>

  <div id="social-list" class="flex flex-col gap-2.5">
    {
      initialLinks.map((link) => (
        <div
          class="social-item hl-card flex flex-col gap-3 p-3.5 sm:flex-row sm:items-center sm:gap-3.5"
          data-id={link.id}
          style={{ opacity: link.isActive ? 1 : 0.62 }}
        >
          <div class="flex min-w-0 items-center gap-3">
            <span class="sortable-handle cursor-grab px-1 active:cursor-grabbing" style="color: var(--hl-ink-3); touch-action: none;">⋮⋮</span>
            <IconPicker id={`social-icon-${link.id}`} value={link.icon} inputClass="social-icon" socialOnly />
            <div class="min-w-0 flex-1">
              <input
                class="social-url hl-input py-1.5 text-[11.5px]"
                value={link.url}
                style="font-family: var(--hl-font-mono); color: var(--hl-ink-3);"
              />
            </div>
          </div>
          <div class="hl-link-item-actions">
            <label class="flex items-center gap-1 text-xs" style="color: var(--hl-ink-2);">
              <input type="checkbox" class="social-active" checked={link.isActive} />
              Active
            </label>
            <label class="flex items-center gap-1 text-xs" style="color: var(--hl-ink-2);">
              <input type="checkbox" class="social-new-tab" checked={link.openInNewTab ?? true} />
              New tab
            </label>
            <button type="button" class="save-social hl-btn hl-btn-soft px-2.5 py-1.5 text-xs">Save</button>
            <button type="button" class="delete-social hl-btn hl-btn-soft px-2.5 py-1.5 text-xs">Delete</button>
          </div>
        </div>
      ))
    }
  </div>

  {
    initialLinks.length === 0 && (
      <p class="py-6 text-center text-sm" style="color: var(--hl-ink-3);">
        No social icons yet. Add Instagram, X, GitHub, and more above.
      </p>
    )
  }

  {
    plan === "free" && initialLinks.length >= maxSocialLinks && (
      <div
        class="hl-card mt-4 flex items-center gap-3 p-3.5"
        style="background: var(--hl-clay-soft); border-color: oklch(0.73 0.082 50 / 0.25);"
      >
        <div class="flex-1 text-[12.5px]">
          You're using <b>{initialLinks.length} of {maxSocialLinks}</b> free social icons.
        </div>
        <a href="/dashboard/billing" class="hl-btn hl-btn-sage px-3 py-1.5 text-xs">Upgrade</a>
      </div>
    )
  }
</div>

<script define:vars={{ urlIconRules }}>
  import { initSortableList } from "../../lib/sortable-list";

  const list = document.getElementById("social-list");
  const errorEl = document.getElementById("social-error");
  const addForm = document.getElementById("add-social-form");

  function showError(msg) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
  }

  function hideError() {
    errorEl?.classList.add("hidden");
  }

  function suggestIconFromUrl(url, currentIcon = "instagram") {
    const input = url.trim();
    if (!input) return currentIcon;

    let haystack = input;
    try {
      const normalized = input.startsWith("http") ? input : `https://${input}`;
      const parsed = new URL(normalized);
      haystack = `${parsed.protocol}//${parsed.hostname}${parsed.pathname}`;
    } catch {
      // keep raw input
    }

    for (const [source, iconId] of urlIconRules) {
      if (new RegExp(source, "i").test(haystack)) return iconId;
    }

    return currentIcon;
  }

  function maybeSuggestIconForRow(row) {
    const urlInput = row.querySelector(".social-url");
    const picker = row.querySelector("[data-icon-picker]");
    const iconInput = row.querySelector(".social-icon");
    if (!urlInput || !picker || !iconInput) return;

    const suggested = suggestIconFromUrl(urlInput.value, iconInput.value);
    if (suggested !== iconInput.value) {
      picker.querySelector(`[data-icon-id="${suggested}"]`)?.click();
    }
  }

  document.getElementById("new-social-url")?.addEventListener("blur", () => {
    const url = document.getElementById("new-social-url")?.value ?? "";
    const picker = document.querySelector("#add-social-form [data-icon-picker]");
    const iconInput = document.getElementById("new-social-icon");
    const suggested = suggestIconFromUrl(url, iconInput?.value ?? "instagram");
    if (picker && suggested !== iconInput?.value) {
      picker.querySelector(`[data-icon-id="${suggested}"]`)?.click();
    }
  });

  list?.addEventListener(
    "blur",
    (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || !target.classList.contains("social-url")) return;
      maybeSuggestIconForRow(target.closest(".social-item"));
    },
    true,
  );

  async function saveSocial(item) {
    const id = item.dataset.id;
    const res = await fetch("/api/links", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        id,
        url: item.querySelector(".social-url")?.value,
        icon: item.querySelector(".social-icon")?.value ?? "instagram",
        isActive: item.querySelector(".social-active")?.checked,
        openInNewTab: item.querySelector(".social-new-tab")?.checked ?? true,
      }),
    });
    const json = await res.json();
    if (!res.ok) showError(json.error || "Save failed");
    else hideError();
  }

  list?.addEventListener("click", async (e) => {
    const target = e.target;
    const item = target.closest(".social-item");
    if (!item) return;

    if (target.classList.contains("save-social")) await saveSocial(item);

    if (target.classList.contains("delete-social")) {
      const res = await fetch("/api/links", {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: item.dataset.id }),
      });
      if (res.ok) {
        item.remove();
        await persistOrder();
      } else {
        const json = await res.json();
        showError(json.error || "Delete failed");
      }
    }
  });

  addForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    hideError();
    const res = await fetch("/api/links", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        url: document.getElementById("new-social-url")?.value,
        icon: document.getElementById("new-social-icon")?.value ?? "instagram",
        openInNewTab: document.getElementById("new-social-open-tab")?.checked ?? true,
        kind: "social",
      }),
    });
    const json = await res.json();
    if (!res.ok) {
      showError(json.error || "Failed to add social icon");
      return;
    }
    window.location.reload();
  });

  async function persistOrder() {
    const order = [...list.querySelectorAll(".social-item")].map((el) => el.dataset.id);
    await fetch("/api/links", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ order, kind: "social" }),
    });
  }

  initSortableList(list, {
    itemSelector: ".social-item",
    handleSelector: ".sortable-handle",
    onReorder: persistOrder,
  });
</script>
