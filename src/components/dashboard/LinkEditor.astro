---
import IconPicker from "./IconPicker.astro";
import { getUrlIconRulesForClient } from "../../lib/link-icons";

interface Props {
  initialLinks: Array<{
    id: string;
    title: string;
    url: string;
    icon: string;
    isActive: boolean;
    openInNewTab: boolean;
    sortOrder: number;
  }>;
  plan: "free" | "pro";
  maxLinks: number;
}

const { initialLinks, plan, maxLinks } = Astro.props;
const urlIconRules = getUrlIconRulesForClient();
---

<div class="hl-dash-scroll p-4 md:p-7">
  <form id="add-link-form" class="mb-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end">
    <div class="min-w-0 flex-1 sm:min-w-[140px]">
      <label class="hl-label" for="new-title">Title</label>
      <input id="new-title" placeholder="Link title" required class="hl-input mt-1" />
    </div>
    <div class="min-w-0 flex-[2] sm:min-w-[200px]">
      <label class="hl-label" for="new-url">URL</label>
      <input id="new-url" placeholder="https://example.com" required class="hl-input mt-1" />
    </div>
    <div>
      <label class="hl-label">Icon</label>
      <div class="mt-1">
        <IconPicker id="new-icon" value="link" />
      </div>
    </div>
    <button type="submit" class="hl-btn hl-btn-primary px-4 py-2.5 text-[13px]">New link</button>
    <label class="flex items-center gap-1.5 self-end pb-2.5 text-xs" style="color: var(--hl-ink-2);">
      <input id="new-open-tab" type="checkbox" checked />
      New tab
    </label>
  </form>

  <p id="link-error" class="mb-4 hidden text-sm" style="color: #b91c1c;"></p>

  <div id="links-list" class="flex flex-col gap-2.5">
    {
      initialLinks.map((link) => (
        <div
          class="link-item hl-card flex flex-col gap-3 p-3.5 sm:flex-row sm:items-center sm:gap-3.5"
          data-id={link.id}
          draggable="true"
          style={{ opacity: link.isActive ? 1 : 0.62 }}
        >
          <div class="flex min-w-0 items-center gap-3">
            <span class="cursor-grab px-1" style="color: var(--hl-ink-3);">⋮⋮</span>
            <IconPicker id={`icon-${link.id}`} value={link.icon} inputClass="link-icon" />
            <div class="min-w-0 flex-1">
              <input class="link-title hl-input mb-1 py-1.5 text-sm font-medium" value={link.title} />
              <input class="link-url hl-input py-1.5 text-[11.5px]" value={link.url} style="font-family: var(--hl-font-mono); color: var(--hl-ink-3);" />
            </div>
          </div>
          <div class="hl-link-item-actions">
            <label class="flex items-center gap-1 text-xs" style="color: var(--hl-ink-2);">
              <input type="checkbox" class="link-active" checked={link.isActive} />
              Active
            </label>
            <label class="flex items-center gap-1 text-xs" style="color: var(--hl-ink-2);">
              <input type="checkbox" class="link-new-tab" checked={link.openInNewTab ?? true} />
              New tab
            </label>
            <button type="button" class="save-link hl-btn hl-btn-soft px-2.5 py-1.5 text-xs">Save</button>
            <button type="button" class="delete-link hl-btn hl-btn-soft px-2.5 py-1.5 text-xs">Delete</button>
          </div>
        </div>
      ))
    }
  </div>

  {
    initialLinks.length === 0 && (
      <p class="py-8 text-center text-sm" style="color: var(--hl-ink-3);">No links yet. Add your first link above.</p>
    )
  }

  {
    plan === "free" && initialLinks.length >= maxLinks && (
      <div
        class="hl-card mt-4 flex items-center gap-3 p-3.5"
        style="background: var(--hl-clay-soft); border-color: oklch(0.73 0.082 50 / 0.25);"
      >
        <div class="flex-1 text-[12.5px]">
          You're using <b>{initialLinks.length} of {maxLinks}</b> free links. Upgrade for unlimited links.
        </div>
        <a href="/dashboard/billing" class="hl-btn hl-btn-sage px-3 py-1.5 text-xs">Upgrade</a>
      </div>
    )
  }
</div>

<script define:vars={{ plan, urlIconRules }}>
  const list = document.getElementById("links-list");
  const errorEl = document.getElementById("link-error");
  const addForm = document.getElementById("add-link-form");

  function showError(msg) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
  }

  function hideError() {
    errorEl?.classList.add("hidden");
  }

  function suggestIconFromUrl(url, currentIcon = "link") {
    const input = url.trim();
    if (!input || (currentIcon && currentIcon !== "link")) return currentIcon;

    let haystack = input;
    try {
      const normalized = input.startsWith("http") ? input : `https://${input}`;
      const parsed = new URL(normalized);
      haystack = `${parsed.protocol}//${parsed.hostname}${parsed.pathname}`;
    } catch {
      // keep raw input
    }

    for (const [source, iconId] of urlIconRules) {
      if (new RegExp(source, "i").test(haystack)) return iconId;
    }

    return currentIcon || "link";
  }

  function maybeSuggestIconForRow(row) {
    const urlInput = row.querySelector(".link-url");
    const picker = row.querySelector("[data-icon-picker]");
    const iconInput = row.querySelector(".link-icon");
    if (!urlInput || !picker || !iconInput) return;

    const suggested = suggestIconFromUrl(urlInput.value, iconInput.value);
    if (suggested !== iconInput.value) {
      const option = picker.querySelector(`[data-icon-id="${suggested}"]`);
      option?.click();
    }
  }

  document.getElementById("new-url")?.addEventListener("blur", () => {
    const url = document.getElementById("new-url")?.value ?? "";
    const picker = document.querySelector("#add-link-form [data-icon-picker]");
    const iconInput = document.getElementById("new-icon");
    const suggested = suggestIconFromUrl(url, iconInput?.value ?? "link");
    if (picker && suggested !== iconInput?.value) {
      picker.querySelector(`[data-icon-id="${suggested}"]`)?.click();
    }
  });

  list?.addEventListener("blur", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement) || !target.classList.contains("link-url")) return;
    maybeSuggestIconForRow(target.closest(".link-item"));
  }, true);

  async function saveLink(item) {
    const id = item.dataset.id;
    const res = await fetch("/api/links", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        id,
        title: item.querySelector(".link-title")?.value,
        url: item.querySelector(".link-url")?.value,
        icon: item.querySelector(".link-icon")?.value ?? "link",
        isActive: item.querySelector(".link-active")?.checked,
        openInNewTab: item.querySelector(".link-new-tab")?.checked ?? true,
      }),
    });
    const json = await res.json();
    if (!res.ok) showError(json.error || "Save failed");
    else hideError();
  }

  list?.addEventListener("click", async (e) => {
    const target = e.target;
    const item = target.closest(".link-item");
    if (!item) return;

    if (target.classList.contains("save-link")) await saveLink(item);

    if (target.classList.contains("delete-link")) {
      const res = await fetch("/api/links", {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: item.dataset.id }),
      });
      if (res.ok) {
        item.remove();
        await persistOrder();
      } else {
        const json = await res.json();
        showError(json.error || "Delete failed");
      }
    }
  });

  addForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    hideError();
    const res = await fetch("/api/links", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        title: document.getElementById("new-title")?.value,
        url: document.getElementById("new-url")?.value,
        icon: document.getElementById("new-icon")?.value ?? "link",
        openInNewTab: document.getElementById("new-open-tab")?.checked ?? true,
      }),
    });
    const json = await res.json();
    if (!res.ok) {
      showError(json.error || "Failed to add link");
      return;
    }
    window.location.reload();
  });

  let draggedItem = null;
  list?.addEventListener("dragstart", (e) => {
    draggedItem = e.target.closest(".link-item");
    if (draggedItem) draggedItem.style.opacity = "0.5";
  });
  list?.addEventListener("dragend", async () => {
    if (draggedItem) draggedItem.style.opacity = "";
    draggedItem = null;
    await persistOrder();
  });
  list?.addEventListener("dragover", (e) => {
    e.preventDefault();
    const afterElement = getDragAfterElement(list, e.clientY);
    if (!draggedItem) return;
    if (afterElement == null) list.appendChild(draggedItem);
    else list.insertBefore(draggedItem, afterElement);
  });

  function getDragAfterElement(container, y) {
    const draggableElements = [...container.querySelectorAll(".link-item:not([style*='opacity: 0.5'])")];
    return draggableElements.reduce(
      (closest, child) => {
        const box = child.getBoundingClientRect();
        const offset = y - box.top - box.height / 2;
        if (offset < 0 && offset > closest.offset) return { offset, element: child };
        return closest;
      },
      { offset: Number.NEGATIVE_INFINITY, element: null },
    ).element;
  }

  async function persistOrder() {
    const order = [...list.querySelectorAll(".link-item")].map((el) => el.dataset.id);
    await fetch("/api/links", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ order, kind: "link" }),
    });
  }
</script>
